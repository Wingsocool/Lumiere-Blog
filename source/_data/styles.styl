//背景图片设置
body {
    background-image: none;
    background-repeat: no-repeat;
    background-attachment: fixed;
    background-size: 100% 100%;
}


/* Local search popup */
.search-popup {
  background: #dcc7aa !important;
  border-radius: 14px;
  box-shadow: 0 12px 36px rgba(0, 0, 0, .18);
}

.search-popup .search-header {
  background: #dcc7aa !important;
  border-bottom: 1px solid #c7ad8b;
}

.search-result-list {
  background: #dcc7aa !important;
}

.search-popup input.search-input {
  color: #3b342f;
  background: #eadbc5 !important;
  border: 1px solid #b9956f;
  border-radius: 10px;
}

.search-popup input.search-input:focus {
  border-color: #9c744d;
  box-shadow: 0 0 0 3px rgba(156, 116, 77, .20);
}

.search-result-list .search-result {
  border-bottom: 1px solid #c7ad8b;
}

.search-result-list .search-result-title {
  color: #4b3524;
}

.search-result-list .search-result-content {
  color: #5b4a3d;
}

.search-keyword {
  color: #4a2b14;
  background: #c89f68;
  border-radius: 3px;
  padding: 0 2px;
}